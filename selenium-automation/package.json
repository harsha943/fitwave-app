{
  "name": "fitwave-selenium-automation",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "Enterprise-level E2E Selenium Automation Testing Framework using Node.js for Fitwave Web App",

  "main": "runner.js",
  "scripts": {
    "start-app": "node server.js",
    "test": "node runner.js",
    "test:parallel": "node runner.js --parallel",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:serve": "allure serve reports/allure-results"
  },
  "dependencies": {
    "allure-mocha": "^2.15.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "minimist": "^1.2.8",
    "mocha": "^10.4.0",
    "multer": "^1.4.5-lts.1",
    "selenium-webdriver": "^4.22.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "allure-commandline": "^2.29.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
